# Backend environment variables
# Copy this to .env or set in Render dashboard

DB_URL=jdbc:sqlite:interview_prep.db

# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=mySecretKeyThatIsAtLeast64CharactersLongForHS512SecurityRequirementPlease!

# Get from cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Get from aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
